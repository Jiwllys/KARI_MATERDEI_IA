from dotenv import load_dotenv
load_dotenv()

import os
import psycopg

DDL = """
CREATE TABLE IF NOT EXISTS familia (
  id SERIAL PRIMARY KEY,
  responsavel_nome TEXT NOT NULL UNIQUE
);

CREATE TABLE IF NOT EXISTS agendamento_familiar (
  id SERIAL PRIMARY KEY,
  familia_id INT NOT NULL REFERENCES familia(id) ON DELETE CASCADE,
  criado_em TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS agendamento_item (
  id SERIAL PRIMARY KEY,
  agendamento_familiar_id INT NOT NULL REFERENCES agendamento_familiar(id) ON DELETE CASCADE,
  ordem INT NOT NULL,
  paciente_nome TEXT NOT NULL,
  especialidade TEXT NOT NULL,
  unidade TEXT NOT NULL,
  data_preferida TEXT NOT NULL,
  periodo TEXT NOT NULL,
  horario TEXT NOT NULL
);

CREATE INDEX IF NOT EXISTS idx_agendamento_familiar_familia_id
  ON agendamento_familiar (familia_id);

CREATE INDEX IF NOT EXISTS idx_agendamento_item_agendamento_familiar_id
  ON agendamento_item (agendamento_familiar_id);
"""

def main():
    url = os.getenv("DATABASE_URL")
    if not url:
        raise RuntimeError("DATABASE_URL não encontrado no .env")

    with psycopg.connect(url) as conn:
        with conn.cursor() as cur:
            cur.execute(DDL)
        conn.commit()

    print("OK: tabelas familia / agendamento_familiar / agendamento_item criadas.")

if __name__ == "__main__":
    main()